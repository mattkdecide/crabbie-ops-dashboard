      }
    },
    "agent_tasks_csv": {
      "Backlog": "backlog",
      "In Progress": "in_progress",
      "Review": "review",
      "Approved": "review",
      "Blocked": "blocked",
      "Done": "done"
    },
    "job_pipeline_csv": {
      "Pinned": "pinned",
      "New": "new",
      "Assessing": "assessing",
      "CV Ready": "cv_ready",
      "Applied": "applied",
      "Interview": "interview",
      "Offer": "offer",
      "Rejected": "rejected",
