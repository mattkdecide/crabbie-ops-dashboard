        "label": "Backlog",
        "terminal": false,
        "allowed_next": ["in_progress", "review", "blocked", "done"]
      },
      "in_progress": {
        "label": "In progress",
        "terminal": false,
        "allowed_next": ["review", "blocked", "done"]
