      "review": {
        "label": "Review",
        "terminal": false,
        "allowed_next": ["in_progress", "blocked", "done"]
      },
      "blocked": {
        "label": "Blocked",
        "terminal": false,
        "allowed_next": ["in_progress", "review", "done"]
      },
      "done": {
        "label": "Done",
        "terminal": true,
        "allowed_next": []
