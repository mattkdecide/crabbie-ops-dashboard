        "label": "Not started",
        "terminal": false,
        "allowed_next": ["drafting", "withdrawn"]
      },
      "drafting": {
        "label": "Drafting",
        "terminal": false,
        "allowed_next": ["submitted", "withdrawn"]
      },
      "submitted": {
        "label": "Submitted",
        "terminal": false,
        "allowed_next": ["interviewing", "rejected", "withdrawn"]
      },
      "interviewing": {
        "label": "Interviewing",
        "terminal": false,
        "allowed_next": ["offer", "rejected", "withdrawn"]
      },
      "offer": {
        "label": "Offer",
        "terminal": true,
        "allowed_next": []
      },
      "rejected": {
        "label": "Rejected",
        "terminal": true,
        "allowed_next": []
      },
      "withdrawn": {
        "label": "Withdrawn",
        "terminal": true,
        "allowed_next": []
      }
    },
    "task": {
